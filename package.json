{
  "name": "differ",
  "version": "1.0.1",
  "description": "Review GitHub and GitLab pull requests from your terminal",
  "main": "./out/main/index.js",
  "bin": {
    "differ": "./out/cli/index.js"
  },
  "author": "ZainW",
  "homepage": "https://github.com/ZainW/differ",
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck:node": "tsgo --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json --composite false",
    "typecheck:site": "tsgo --noEmit -p tsconfig.site.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web && pnpm run typecheck:site",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --format=cjs --outfile=out/cli/index.js --packages=external --external:electron",
    "build:site": "vite build --config vite.site.config.ts",
    "build:visual": "vite build --config vite.visual.config.ts",
    "site:dev": "vite --config vite.site.config.ts",
    "site:preview": "vite preview --config vite.site.config.ts",
    "differ": "node scripts/run-differ.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build && pnpm run build:cli",
    "postinstall": "node scripts/install-app-deps.mjs",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "test": "vitest run",
    "test:visual": "pnpm build:visual && playwright test",
    "test:visual:update": "pnpm build:visual && playwright test --update-snapshots",
    "test:visual:report": "playwright show-report playwright-report"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@pierre/diffs": "^1.2.3",
    "@pierre/trees": "1.0.0-beta.4",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260526.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "6.0.0-beta.1",
    "esbuild": "^0.28.0",
    "lucide-react": "^1.18.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
